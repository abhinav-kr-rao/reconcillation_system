{
  "compilerOptions": {
    "target": "es2022",                                  
    "module": "commonjs",   
    "moduleResolution": "node",                             
    "rootDir": "./",                                     
    "outDir": "dist1",                                  
    "esModuleInterop": true,                             
    "forceConsistentCasingInFileNames": true,            
    "strict": true,                                      
    "skipLibCheck": true                            
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist1"
  ]
}